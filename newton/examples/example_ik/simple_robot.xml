<mujoco model="simple_robot">
  <compiler angle="radian" autolimits="true"/>
  
  <default>
    <joint damping="0.1" armature="0.01"/>
    <geom contype="1" conaffinity="1" friction="0.7 0.1 0.1"/>
  </default>
  
  <worldbody>
    <!-- Base link -->
    <body name="base" pos="0 0 0.5">
      <joint name="joint1" type="hinge" axis="0 0 1" range="-3.14 3.14"/>
      <geom name="base_geom" type="box" size="0.1 0.1 0.25" rgba="0.8 0.2 0.2 1"/>
      
      <!-- Link 1 -->
      <body name="link1" pos="0 0 0.5">
        <joint name="joint2" type="slide" axis="1 0 0" range="-0.5 0.5"/>
        <geom name="link1_geom" type="box" size="0.05 0.05 0.25" rgba="0.2 0.8 0.2 1"/>
        
        <!-- Link 2 (end-effector) -->
        <body name="link2" pos="0 0 0.5">
          <joint name="joint3" type="hinge" axis="0 1 0" range="-1.57 1.57"/>
          <geom name="link2_geom" type="box" size="0.04 0.04 0.2" rgba="0.2 0.2 0.8 1"/>
        </body>
      </body>
    </body>
  </worldbody>
</mujoco>