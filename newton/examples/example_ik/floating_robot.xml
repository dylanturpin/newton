<mujoco model="floating_robot">
  <compiler angle="radian" autolimits="true"/>
  
  <default>
    <joint damping="0.1" armature="0.01"/>
    <geom contype="1" conaffinity="1" friction="0.7 0.1 0.1"/>
  </default>
  
  <worldbody>
    <!-- Floating base -->
    <body name="base" pos="0 0 1">
      <freejoint name="base_joint"/>
      <geom name="base_geom" type="box" size="0.15 0.15 0.1" rgba="0.8 0.2 0.2 1"/>
      
      <!-- Link 1 -->
      <body name="link1" pos="0 0 0.2">
        <joint name="joint1" type="hinge" axis="0 0 1" range="-3.14 3.14"/>
        <geom name="link1_geom" type="cylinder" size="0.05 0.15" rgba="0.2 0.8 0.2 1"/>
        
        <!-- Link 2 -->
        <body name="link2" pos="0 0 0.3">
          <joint name="joint2" type="hinge" axis="0 1 0" range="-1.57 1.57"/>
          <geom name="link2_geom" type="cylinder" size="0.04 0.15" rgba="0.2 0.2 0.8 1"/>
          
          <!-- End-effector link -->
          <body name="ee_link" pos="0 0 0.3">
            <joint name="joint3" type="hinge" axis="1 0 0" range="-1.57 1.57"/>
            <geom name="ee_geom" type="sphere" size="0.03" rgba="0.8 0.8 0.2 1"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>
</mujoco>